{
  "builds": [
    { "src": "api/main.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "game.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/main.py" },
    { "src": "/game", "dest": "/game.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
